# RPC URL for Base — only needed for live data fetching.
# The demo works out of the box with seeded data, no key required.
# Moralis example:
RPC_URL=https://site1.moralis-nodes.com/base/YOUR_KEY_HERE

# Chain config
CHAIN_ID=8453

# Target pool: USDC/WETH 0.05% on Base
POOL_ADDRESS=0xd0b53D9277642d899DF5C87A3966A349A798F224
POOL_FEE_TIER=0.0005

# Block range for ingestion (set to a recent ~3-7 day window)
FROM_BLOCK=
TO_BLOCK=

# API port
API_PORT=3001
